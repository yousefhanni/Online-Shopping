@model IEnumerable<Category>
@{
    ViewData["Title"] = "Index";
}
<h3>All Categories</h3>
<br />
<a asp-action="Create" class="btn btn-primary">Create Category</a>
<br />
<table class="mt-3 table table-scripted table-hover">
    <thead>
        <tr>
         <th>@Html.DisplayNameFor(D => D.Name)</th>
            <th>@Html.DisplayNameFor(D => D.Description)</th>
            <th>@Html.DisplayNameFor(D => D.DateOfCreation)</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td>@category.Name</td>
                <td style="word-wrap: break-word;min-width: 160px;max-width:200px">@category.Description</td>
                <td>@category.DateOfCreation</td>

                <partial name="_ButtonsPartialView" model="@category.Id" />
            </tr>
            <tr>
                <td colspan="5"></td> <!-- This will create an empty cell spanning all columns -->
            </tr>
        }
    </tbody>
</table>
